generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Unidad {
  id                   Int          @id @default(autoincrement())
  descripcion          String       @db.VarChar(100)
  activo               Boolean      @default(true)
  usuario_registro     String       @db.VarChar(100)
  fecha_registro       DateTime     @default(now())
  usuario_modificacion String?      @db.VarChar(100)
  fecha_modificacion   DateTime?
  cotizaciones         Cotizacion[]

  @@map("unidad")
}

model Pais {
  id                   Int          @id @default(autoincrement())
  nombre               String       @db.VarChar(100)
  orden                Int
  activo               Boolean      @default(true)
  usuario_registro     String       @db.VarChar(100)
  fecha_registro       DateTime     @default(now())
  usuario_modificacion String?      @db.VarChar(100)
  fecha_modificacion   DateTime?
  cotizaciones         Cotizacion[]

  @@map("pais")
}

model TipoProducto {
  id                   Int          @id @default(autoincrement())
  descripcion          String       @db.VarChar(100)
  factor               Decimal      @db.Decimal(5, 2)
  activo               Boolean      @default(true)
  usuario_registro     String       @db.VarChar(100)
  fecha_registro       DateTime     @default(now())
  usuario_modificacion String?      @db.VarChar(100)
  fecha_modificacion   DateTime?
  cotizaciones         Cotizacion[]

  @@map("tipo_producto")
}

model Cotizacion {
  id                   Int          @id @default(autoincrement())
  tipo_cotizacion      String       @db.VarChar(3)
  producto             String       @db.VarChar(200)
  costo_unitario       Decimal      @db.Decimal(11, 2)
  cantidad             Decimal      @db.Decimal(11, 6)
  unidad_id            Int
  cbm                  Decimal      @db.Decimal(11, 6)
  peso                 Decimal      @db.Decimal(11, 6)
  hs_code              String       @db.VarChar(200)
  incoterm             String       @db.VarChar(200)
  pais_id              Int
  puerto_final         String       @db.VarChar(200)
  destino_final        String       @db.VarChar(200)
  fob_total            Decimal      @db.Decimal(11, 2)
  flete_maritimo       Decimal      @db.Decimal(11, 2)
  seguro               Decimal      @db.Decimal(11, 2)
  arancel              Decimal      @db.Decimal(11, 2)
  agente_aduanal       Decimal      @db.Decimal(11, 2)
  transporte_local     Decimal      @db.Decimal(11, 2)
  otros_gastos         Decimal      @db.Decimal(11, 2)
  ddp_total            Decimal      @db.Decimal(11, 2)
  ddp_unitario         Decimal      @db.Decimal(11, 2)
  tipo_producto_id     Int
  factor               Decimal      @db.Decimal(5, 2)
  costo_x_m3           Decimal      @db.Decimal(11, 2)
  cbm_x_costo          Decimal      @db.Decimal(11, 2)
  peso_x_costo         Decimal      @db.Decimal(11, 2)
  usuario_id           Int
  activo               Boolean      @default(true)
  usuario_registro     String       @db.VarChar(100)
  fecha_registro       DateTime     @default(now())
  usuario_modificacion String?      @db.VarChar(100)
  fecha_modificacion   DateTime?
  unidad               Unidad       @relation(fields: [unidad_id], references: [id])
  pais                 Pais         @relation(fields: [pais_id], references: [id])
  tipo_producto        TipoProducto @relation(fields: [tipo_producto_id], references: [id])
  usuario              Usuario      @relation(fields: [usuario_id], references: [id])

  @@map("cotizacion")
}

model Usuario {
  id                   Int          @id @default(autoincrement())
  nombre               String       @db.VarChar(200)
  correo               String       @unique @db.VarChar(255)
  password_hash        String       @db.VarChar(255)
  celular              String       @db.VarChar(15)
  alias                String       @default("") @db.VarChar(30)
  reset_token          String?      @db.VarChar(255)
  reset_token_expira   DateTime?
  activo               Boolean      @default(true)
  usuario_registro     String       @db.VarChar(100)
  fecha_registro       DateTime     @default(now())
  usuario_modificacion String?      @db.VarChar(100)
  fecha_modificacion   DateTime?
  roles                UsuarioRol[]
  cotizaciones         Cotizacion[]

  @@map("usuario")
}

model Rol {
  id                   Int          @id
  nombre               String       @db.VarChar(50)
  activo               Boolean      @default(true)
  usuario_registro     String       @db.VarChar(100)
  fecha_registro       DateTime     @default(now())
  usuario_modificacion String?      @db.VarChar(100)
  fecha_modificacion   DateTime?
  usuarios             UsuarioRol[]

  @@map("rol")
}

model UsuarioRol {
  id                   Int       @id @default(autoincrement())
  usuario_id           Int
  rol_id               Int
  activo               Boolean   @default(true)
  usuario_registro     String    @db.VarChar(100)
  fecha_registro       DateTime  @default(now())
  usuario_modificacion String?   @db.VarChar(100)
  fecha_modificacion   DateTime?
  usuario              Usuario   @relation(fields: [usuario_id], references: [id])
  rol                  Rol       @relation(fields: [rol_id], references: [id])

  @@index([usuario_id, rol_id])
  @@map("usuario_rol")
}

model Configuracion {
  configuracionid      Int       @id @default(autoincrement())
  nombre               String    @unique @db.VarChar(200)
  valor                String
  activo               Boolean   @default(true)
  fecharegistro        DateTime  @default(now())
  fechamodificacion    DateTime?
  usuarioregistro      String    @db.VarChar(100)
  usuariomodificacion  String?   @db.VarChar(100)

  @@map("configuracion")
}